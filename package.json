{
  "name": "car-aggregator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "backup":         "node scripts/backup.js",
    "normalize":      "node scripts/normalize.js",
    "baselines":      "node scripts/compute_baselines.js",
    "score":          "node scripts/score.js",
    "validate:phase-a": "node scripts/validate-phase-a.js",
    "scrape:syarah":     "node scripts/scrapers/syarah.js",
    "scrape:motory":     "node scripts/scrapers/motory.js",
    "scrape:yallamotor": "node scripts/scrapers/yallamotor.js",
    "scrape:gogomotor":  "node scripts/scrapers/gogomotor.js",
    "scrape:saudisale":  "node scripts/scrapers/saudisale.js",
    "scrape:soum":       "node scripts/scrapers/soum.js",
    "scrape:carswitch":  "node scripts/scrapers/carswitch.js",
    "scrape:dubizzle":   "node scripts/scrapers/dubizzle.js",
    "scrape:digitalcar": "node scripts/scrapers/digitalcar.js",
    "scrape:haraj":      "node scripts/scrapers/haraj.js",
    "scrape:all": "npm run scrape:syarah && npm run scrape:motory && npm run scrape:yallamotor && npm run scrape:gogomotor && npm run scrape:saudisale && npm run scrape:carswitch && npm run scrape:dubizzle && npm run scrape:digitalcar",
    "pipeline:full":    "npm run scrape:all && npm run normalize && npm run baselines && npm run score",
    "pipeline:refresh": "node scripts/pipeline_full.js",
    "pipeline:status":  "node scripts/pipeline_status.js",
    "freshness:sweep":  "node scripts/freshness_check.js"
